	line-height:24px;
}

.info_list{
	margin: 0px;
	padding: 0px;
}

.info_list li{
	font-size: 15px;
	font-weight: 400;
	line-height:24px;
	margin-bottom: 10px;
	color: #fff !important;
}

.widget ul li{
	line-height: 25px;
	font-size: 15px;
	color: #efefef;
}

.footer-big ul li{
	font-weight: 400;
}

.footer-big ul li a{
	   text-transform: capitalize;
    font-weight: 400 !important;
	  color: #efefef;
}

.footer-big p {
    color: #efefef;
}

.widget .wp-block-heading{
	font-weight: 500 !important;
	font-size: 24px;
}

