	box-shadow: 0px 0px 0px 8px #ffffff;
}

.contact_form{
	width: 100%;
	box-shadow: 0px 0px 10px 0px #e2e2e2;
	padding: 40px;
	border-radius: 12px;
}

.contact_form label{
	width: 100%;
	font-weight: 400;
}

.contact_form input{
	padding: 22px 2px;
	margin-bottom: 10px;
}

.contact_form ::placeholder{
	color: #444;
} 

.contact_form .wpcf7-form-control.wpcf7-select{
	width: 100%;
	border: none;
	border-bottom: 1px solid #dddd;
	padding: 14px 0px;
	margin-bottom: 16px;
}

.contact_form .wpcf7-form-control.wpcf7-textarea.form-control{
	width: 100%;
	height: 100px !important;
}

.mnheading h1{
	position: relative;
	
}

.mnheading h1:after{
	content: '';
	width: 200px;
	height: 3px;
	background-color: #dd2525;
	position: absolute;
	bottom: -10px;
	left: 50%;
	transform: translate(-50%);
	z-index: 1;
}

.social_link{
	margin: 0px;
	padding:0px;
	display: flex;
	align-items: center;
	column-gap: 6px
}

