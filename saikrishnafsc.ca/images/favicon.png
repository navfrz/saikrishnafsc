	font-size: 15px;
}

.retailer_card{
	width: 100%;
	display: grid;
	grid-template-columns: 1fr 150px;
	column-gap: 30px;
}

.wholsimg{
	width: 100%;
	border: 8px solid #fff;
}

.wholsimg img{
		width: 100%;
		height: 100%;
	}

