.samosa_list li a{
	color: #444;
}

.samosa_list li a:hover{
	color:#af0011;
}

.servbox{
	        box-shadow: 0px 2px 14px 0px #0000000d;
    padding: 20px;
    border-radius: 10px;
	background-color:#fff;
	transition: all 0.3s ease-in-out;
}

.servbox:hover{
	transform: translateY(-8px);
    box-shadow: 0px 4px 20px 0px #00000017;
}

.servbox h3{
	max-width: 180px;
	margin: 0px auto;
	font-size: 18px;
	line-height: 26px;
	font-weight: 500;
	margin-top: 12px;
}

.wptww-testimonial-content{
	margin-top: 20px;
}


.wptww-testimonial-content h4{
	display: none;
}

.wptww-testimonials-text p{
	font-size: 16px !important;
	color: #333;
}

.wptww-testimonials-text p em{
		 font-style: inherit;
}


.wptww-testimonials-slidelist button{
	box-shadow: none !important;
}

.wptww-testimonial-content .fa.fa-quote-left{
	display: none !important;
}

.metaslider .flex-control-nav{
	    bottom: 25px !important;
}

